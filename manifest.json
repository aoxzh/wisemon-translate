{
  "manifest_version": 3,
  "name": "wisemon-translate",
  "version": "1.0.6",
  "description": "AI-powered bilingual web page translation. DeepSeek, OpenAI, or any compatible LLM. Just bring your own API key.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "alarms",
    "sidePanel"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "wisemon-translate"
  },
  "options_page": "options.html",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content_guard.js"
      ],
      "css": [
        "content_style.css"
      ],
      "run_at": "document_end",
      "all_frames": true,
      "match_about_blank": false
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L"
      }
    },
    "toggle-translation": {
      "suggested_key": {
        "default": "Alt+T"
      },
      "description": "Toggle page translation"
    },
    "toggle-hover": {
      "suggested_key": {
        "default": "Alt+H"
      },
      "description": "Toggle hover translation mode"
    },
    "toggle-only-translation": {
      "suggested_key": {
        "default": "Alt+R"
      },
      "description": "Toggle translation-only / bilingual mode"
    },
    "translate-to-bottom": {
      "description": "Translate all remaining content to page end"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/lib/site-rules.json",
        "src/content/ui/inline-styles.css",
        "src/injectors/shadowroot-patcher.js",
        "src/injectors/youtube-subtitle-injector.js",
        "src/injectors/netflix-subtitle-injector.js",
        "src/injectors/bilibili-subtitle-injector.js"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ]
}
