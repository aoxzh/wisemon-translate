{
  "manifest_version": 3,
  "name": "wisemon-translate",
  "version": "1.0.6",
  "description": "AI-powered bilingual web page translation. DeepSeek, OpenAI, or any compatible LLM. Just bring your own API key.",
  "browser_specific_settings": {
    "gecko": {
      "id": "wisemon@example.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "authenticationInfo",
          "browsingActivity",
          "websiteContent"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "src/lib/i18n.js",
      "src/lib/i18n-locales/common.js",
      "src/lib/i18n-locales/options-general.js",
      "src/lib/i18n-locales/options-translation.js",
      "src/lib/i18n-locales/options-features.js",
      "src/lib/i18n-locales/themes.js",
      "src/lib/utils.js",
      "src/lib/providers.js",
      "src/lib/logger.js",
      "src/lib/batch-queue.js",
      "src/lib/site-rules.js",
      "src/lib/llm-api.js",
      "src/lib/llm-adapters/batch.js",
      "src/lib/provider-loader.js",
      "src/lib/providers/anthropic.js",
      "src/lib/providers/google.js",
      "src/lib/providers/deepl.js",
      "src/lib/providers/baidu.js",
      "src/lib/providers/microsoft.js",
      "background.js"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
      "default_title": "wisemon-translate"
  },
  "options_page": "options.html",
  "sidebar_action": {
    "default_title": "wisemon-translate Reader",
    "default_panel": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content_guard.js"
      ],
      "css": [
        "content_style.css"
      ],
      "run_at": "document_end",
      "all_frames": true,
      "match_about_blank": false
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L"
      }
    },
    "toggle-translation": {
      "suggested_key": {
        "default": "Alt+T"
      },
      "description": "Toggle page translation"
    },
    "toggle-hover": {
      "suggested_key": {
        "default": "Alt+H"
      },
      "description": "Toggle hover translation mode"
    },
    "toggle-only-translation": {
      "suggested_key": {
        "default": "Alt+R"
      },
      "description": "Toggle translation-only / bilingual mode"
    },
    "translate-to-bottom": {
      "description": "Translate all remaining content to page end"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/lib/site-rules.json",
        "src/content/ui/inline-styles.css",
        "src/injectors/shadowroot-patcher.js",
        "src/injectors/youtube-subtitle-injector.js",
        "src/injectors/netflix-subtitle-injector.js",
        "src/injectors/bilibili-subtitle-injector.js"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ]
}
